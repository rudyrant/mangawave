<%- include('../partials/head', { pageTitle }) %>
<%- include('../partials/header') %>
<main class="shell section-gap">
  <section class="auth-shell panel">
    <div class="stack-md">
      <p class="eyebrow"><%= t('forgotEyebrow') %></p>
      <h1><%= t('forgotTitle') %></h1>
      <p class="lead"><%= t('forgotLead') %></p>
      <form action="/forgot-password" method="post" class="stack-md">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input class="input" type="email" name="email" placeholder="<%= t('forgotEmailPlaceholder') %>" required />
        <button class="button button-primary" type="submit"><%= t('forgotButton') %></button>
      </form>
      <p class="muted"><%= t('forgotResetNote') %></p>
    </div>
    <div class="panel-soft auth-aside">
      <p class="eyebrow"><%= t('forgotSafetyEyebrow') %></p>
      <ul>
        <li><%= t('forgotSafetyOne') %></li>
        <li><%= t('forgotSafetyTwo') %></li>
        <li><%= t('forgotSafetyThree') %></li>
      </ul>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
