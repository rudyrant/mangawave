<%- include('../partials/head', { pageTitle }) %>
<%- include('../partials/header') %>
<main class="shell section-gap">
  <section class="auth-shell panel">
    <div class="stack-md">
      <p class="eyebrow"><%= t('forgotEyebrow') %></p>
      <h1><%= t('resetTitle') %></h1>
      <% if (validToken) { %>
        <form action="/reset-password" method="post" class="stack-md">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" name="token" value="<%= token %>" />
          <input class="input" type="password" name="password" placeholder="<%= t('resetNewPasswordPlaceholder') %>" required />
          <input class="input" type="password" name="confirmPassword" placeholder="<%= t('resetConfirmPasswordPlaceholder') %>" required />
          <button class="button button-primary" type="submit"><%= t('resetButton') %></button>
        </form>
        <p class="muted"><%= t('resetPasswordHint') %></p>
      <% } else { %>
        <p class="lead"><%= t('resetInvalidTokenLead') %></p>
        <div class="button-row"><a href="/forgot-password" class="button button-primary"><%= t('resetRequestNew') %></a></div>
      <% } %>
    </div>
    <div class="panel-soft auth-aside">
      <p class="eyebrow"><%= t('resetExpiryEyebrow') %></p>
      <p class="muted"><%= t('resetExpiryLead') %></p>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
